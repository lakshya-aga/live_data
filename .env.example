# ── Server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8765

# ── GROWW (developer.groww.in) ──────────────────────────────────────────
# Register at https://developer.groww.in to obtain these credentials.
GROWW_API_KEY=
GROWW_API_SECRET=
# Optional: pre-generated access token (skips OAuth flow at startup)
GROWW_ACCESS_TOKEN=

# ── NSE public data (no key required) ───────────────────────────────────
NSE_POLL_INTERVAL=5          # seconds between quote polls (no WS fallback)

# ── GDELT ───────────────────────────────────────────────────────────────
GDELT_POLL_INTERVAL=300      # seconds
# Space-separated GDELT V2 themes to monitor
GDELT_THEMES=ECON_STOCKMARKET ECON_DEBT ECON_BANKRUPT EPU_POLICY_INDIA

# ── News RSS ─────────────────────────────────────────────────────────────
NEWS_POLL_INTERVAL=60        # seconds
# Comma-separated list of additional RSS feed URLs (built-ins always included)
EXTRA_RSS_FEEDS=

# ── Financials ──────────────────────────────────────────────────────────
FINANCIALS_POLL_INTERVAL=3600   # 1 hour
SCREENER_API_KEY=               # optional, Screener.in API key

# ── Corporate events ────────────────────────────────────────────────────
CORPORATE_EVENTS_POLL_INTERVAL=300   # 5 minutes

# ── Insider / holdings ──────────────────────────────────────────────────
BULK_BLOCK_POLL_INTERVAL=900      # 15 min — intraday signal
SEBI_INSIDER_POLL_INTERVAL=3600   # 1 hour — disclosures filed within 2 trading days
FII_DII_POLL_INTERVAL=3600        # 1 hour — published at end of day
POLITICIAN_HOLDINGS_POLL_INTERVAL=86400  # once a day — election-cycle data

# ── Company / governance ─────────────────────────────────────────────────
SHAREHOLDING_POLL_INTERVAL=21600  # 6 hours — NSE quarterly filings
BOARD_POLL_INTERVAL=86400         # once a day — director change detection

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console   # "console" or "json"

# ── Watchlist ────────────────────────────────────────────────────────────
# Comma-separated NSE symbols; empty = built-in Nifty-50 subset
WATCHLIST=
